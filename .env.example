# Google Gemini API (https://aistudio.google.com/apikey)
# 支援多組 key，逗號分隔，額度用盡自動輪換
GEMINI_API_KEY=key1,key2,key3

# Telegram Bot (https://t.me/BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=

# Telegram Channels (add bot as admin to each channel)
TELEGRAM_CHANNEL_AI=@newsbot_ai
TELEGRAM_CHANNEL_INVEST=@newsbot_invest
TELEGRAM_CHANNEL_CRYPTO=@newsbot_crypto
TELEGRAM_CHANNEL_GEO=@newsbot_geo
TELEGRAM_CHANNEL_ACTUARY=@newsbot_actuary
